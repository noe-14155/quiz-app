# Copie ce fichier en ".env" (ou renseigne ces mêmes valeurs directement dans
# les "Environment variables" de Portainer si tu déploies via Repository —
# dans ce cas, pas besoin de fichier .env physique du tout).

# Port externe exposé sur le VPS pour accéder à l'API (phase de test, avant
# la configuration nginx définitive) : http://TON_IP:EXTERNAL_PORT
EXTERNAL_PORT=8001

# Port externe pour l'interface du quiz (frontend) : http://TON_IP:FRONTEND_PORT
FRONTEND_PORT=8080

# Adresse à laquelle le frontend ira chercher l'API — figée dans les fichiers
# statiques au moment du build, à changer ici si l'adresse de l'API évolue
# (nouveau domaine, HTTPS...) puis reconstruire l'image frontend.
VITE_API_BASE_URL=http://87.106.2.201:8001

# Dossier ABSOLU sur le VPS contenant questions.csv (et où quiz.db sera créé).
# Doit exister avant le premier démarrage du conteneur.
DATA_DIR=/root/quiz-data
